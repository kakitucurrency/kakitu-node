Name:                   kakitu
Version:                @VERSION@
Release:                @RELEASE@%{?dist}
Summary:                Kakitu Currency Daemon
License:                BSD-2-Clause
URL:                    https://kakitu.org
Requires(pre):          /usr/sbin/useradd, /usr/bin/getent
Requires(postun):       /usr/sbin/userdel
BuildRequires:          make, libstdc++-static, glibc-devel, glibc-headers
Source:                 nano-%{version}.tar.gz

%description
This is Kakitu Currency daemon.  Kakitu is a digital currency that is
peer-to-peer, decentralized, and trustless. This package includes
the kakitu daemon, and a service.

%prep
if [ ! -x "$(which cmake)" ]; then
	echo "cmake must exist, try:" >&2
	echo "      scl enable devtoolset-7 'rpmbuild ...'" >&2
	exit 1
fi
if cc --std=c++14 --version 2>&1 >/dev/null | grep '^' >/dev/null; then
	echo "Unsupported C++ compiler, try:" >&2
	echo "      scl enable devtoolset-7 'rpmbuild ...'" >&2
	exit 1
fi
if test ! -d /usr/local/boost; then
	echo "Boost should be in /usr/local/boost" >&2
	exit 1
fi
%autosetup -n nano-%{version}

%build
cmake -DCMAKE_VERBOSE_MAKEFILE=ON -DBOOST_ROOT=/usr/local/boost .
make kakitu_node %{?_smp_mflags}
make kakitu_rpc %{?_smp_mflags}

%install
if [ ! %{buildroot} = "/" ]; then %{__rm} -rf %{buildroot}; fi
mkdir -p %{buildroot}/usr/bin
mkdir -p %{buildroot}/etc/systemd/system/
cp kakitu_node %{buildroot}/usr/bin/kakitu_node
cp kakitu_rpc %{buildroot}/usr/bin/kakitu_rpc
cp etc/systemd/kakitu.service %{buildroot}/etc/systemd/system/kakitu.service

%clean
if [ ! %{buildroot} = "/" ]; then %{__rm} -rf %{buildroot}; fi

%files
%defattr(755,root,root)
%{_bindir}/kakitu_node
%{_bindir}/kakitu_rpc
%attr(644,root,root) /etc/systemd/system/kakitu.service

%pre
PATH="/usr/bin:/usr/sbin:/bin:/sbin:${PATH}"; export PATH
mkdir -p /var/kakitu/Kakitu
getent group kakitu >/dev/null || groupadd --system kakitu || exit 1
getent passwd kakitu >/dev/null || useradd --system --create-home --home-dir /var/kakitu --shell /bin/bash --comment "Kakitu Currency Daemon user" --gid kakitu kakitu || exit 1
chown -R kakitu:kakitu /var/kakitu
chmod 700 /var/kakitu

%post
systemctl daemon-reload >/dev/null 2>&1 || :
systemctl enable kakitu.service >/dev/null 2>&1 || :

%postun
PATH="/usr/bin:/usr/sbin:/bin:/sbin:${PATH}"; export PATH
userdel kakitu >/dev/null 2>/dev/null || :
